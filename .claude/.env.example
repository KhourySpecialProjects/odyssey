# Claude Code tooling environment variables
# Copy this file to .claude/.env and fill in your values

# Linear API integration (used by the auditor agent to create tickets)
# Get your API key from: Linear → Settings → Account → Security & Access → API keys
LINEAR_API_KEY=lin_api_xxxxx

# Get your Team ID by running:
# curl -s -X POST https://api.linear.app/graphql \
#   -H "Authorization: $LINEAR_API_KEY" \
#   -H "Content-Type: application/json" \
#   --data '{"query": "query { teams { nodes { id name } } }"}'
LINEAR_TEAM_ID=your-team-uuid

# Get your Bug label ID by running:
# curl -s -X POST https://api.linear.app/graphql \
#   -H "Authorization: $LINEAR_API_KEY" \
#   -H "Content-Type: application/json" \
#   --data '{"query": "query { issueLabels { nodes { id name } } }"}'
LINEAR_BUG_LABEL_ID=your-bug-label-uuid
