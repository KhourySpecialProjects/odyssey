{
  "kind": "collectionType",
  "collectionName": "lessons",
  "info": {
    "singularName": "lesson",
    "pluralName": "lessons",
    "displayName": "Lesson"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "droplets.generic",
        "droplets.video"
      ],
      "required": true
    },
    "droplets": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::droplet.droplet",
      "mappedBy": "lessons"
    }
  }
}
