{
  "kind": "collectionType",
  "collectionName": "lessons",
  "info": {
    "singularName": "lesson",
    "pluralName": "lessons",
    "displayName": "Lesson",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "droplets.generic",
        "droplets.video",
        "droplets.quiz",
        "droplets.callout",
        "droplets.expandable",
        "droplets.open-ended-quiz"
      ],
      "required": false
    },
    "blocksVersion": {
      "type": "enumeration",
      "enum": [
        "v1",
        "v2"
      ],
      "default": "v1"
    },
    "blocksV2": {
      "type": "json"
    },
    "droplets": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::droplet.droplet",
      "mappedBy": "lessons"
    },
    "enrollments": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::enrollment.enrollment",
      "mappedBy": "viewedLessons"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "general",
        "setup",
        "activity",
        "caseStudy"
      ],
      "default": "general"
    },
    "droplet_lessons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::droplet-lesson.droplet-lesson",
      "mappedBy": "lesson"
    },
    "notes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::note.note",
      "mappedBy": "lesson"
    },
    "highlights": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::highlight.highlight",
      "mappedBy": "lesson"
    },
    "orderIndex": {
      "type": "integer"
    },
    "lockedBy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::authorized-user.authorized-user"
    },
    "lockedAt": {
      "type": "datetime"
    }
  }
}
