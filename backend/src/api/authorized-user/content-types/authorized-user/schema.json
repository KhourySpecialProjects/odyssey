{
  "kind": "collectionType",
  "collectionName": "authorized_users",
  "info": {
    "singularName": "authorized-user",
    "pluralName": "authorized-users",
    "displayName": "Authorized User",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "isEnabled": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "author": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::author.author",
      "mappedBy": "authorizedUser"
    },
    "enrollments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::enrollment.enrollment",
      "mappedBy": "authorizedUser"
    },
    "roles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::authorized-user-role.authorized-user-role",
      "mappedBy": "authorizedUsers"
    },
    "playlists": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::playlist.playlist",
      "mappedBy": "authorized_users"
    },
    "linkedin": {
      "type": "string"
    },
    "github": {
      "type": "string"
    },
    "firstTime": {
      "type": "boolean",
      "default": true
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "bio": {
      "type": "text",
      "maxLength": 400
    }
  }
}
