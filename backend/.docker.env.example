# Overrides for docker compose. Match values to backend/.env DATABASE_*
DATABASE_HOST=strapiDB
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# Postgres container init. Set these to the same values as DATABASE_USERNAME,
# DATABASE_PASSWORD, and DATABASE_NAME above. docker-compose does NOT expand
# ${...} references inside env_file, so you must write the concrete values here.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
