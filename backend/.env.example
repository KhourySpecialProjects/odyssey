HOST=0.0.0.0
PORT=1337

# Strapi secrets (generate with: openssl rand -base64 32)
APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=

# AWS S3 (media uploads)
AWS_CDN_URL=
AWS_CDN_ROOT_PATH=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION=
AWS_S3_ENDPOINT=
AWS_S3_BUCKET=

# Database (local postgres)
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SSL=false

# Slack notifications. PROD ONLY. Leave empty for local/dev (backend skips
# the notification call when unset). Real value is in AWS Secrets Manager;
# ask a team member if you need to exercise this path outside production.
SLACK_WEBHOOK_URL=
