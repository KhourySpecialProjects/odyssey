{
  "scripts": {
    "frontend": "npm run dev --prefix ./frontend/",
    "backend": "npm run dev --prefix ./backend/",
    "clear": "cd frontend && rm -rf .next && rm -rf cache",
    "setup:frontend": "cd frontend && npm install",
    "setup:backend": "cd backend && npm install",
    "setup": "npm install install && npm run setup:frontend && npm run setup:backend",
    "dev": "npm run clear && concurrently \"cd frontend && npm run dev\" \"cd backend && npm run dev\"",
    "prettier-check": "npx prettier . --check",
    "prettier-write": "npx prettier . --write"
  },
  "dependencies": {
    "@aarkue/tiptap-math-extension": "^1.3.4",
    "@aws-sdk/client-s3": "^3.701.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^6.4.5",
    "@mui/x-date-pickers": "^7.27.0",
    "@nextui-org/table": "^2.2.8",
    "@tiptap/extension-color": "^2.11.5",
    "@tiptap/extension-text-style": "^2.11.5",
    "@types/luxon": "^3.4.2",
    "@types/react-tabs": "^5.0.4",
    "canvas-confetti": "^1.9.3",
    "concurrently": "^8.2.2",
    "confetti": "^2.0.3",
    "dayjs": "^1.11.13",
    "install": "^0.13.0",
    "katex": "^0.16.21",
    "luxon": "^3.5.0",
    "next": "^15.1.3",
    "npm-check-updates": "^16.14.15",
    "pdf-lib": "^1.17.1",
    "react-confetti": "^6.2.2",
    "react-datetime-picker": "^6.0.1",
    "react-dropzone": "^14.3.5",
    "react-router-dom": "^7.1.5",
    "react-tabs": "^6.1.0",
    "reactjs-popup": "^2.0.6"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "prettier": "3.3.2"
  }
}
