      "required": true
    },
    "college": {
      "type": "enumeration",
      "enum": [
        "BV",
        "CAMD",
        "COE",
        "CPS",
        "COS",
        "CSSH",
        "DMSB",
        "KCCS",
        "MI",
        "LAW",
        "other"
      ],
      "required": true
    }
